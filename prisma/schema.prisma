generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  status    ContactStatus @default(UNREAD)
  source    String        @default("website")
  ipAddress String?
  userAgent String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  repliedAt DateTime?
  repliedBy String?
  notes     String?

  @@index([status, createdAt])
  @@index([email])
  @@index([createdAt])
}

enum ContactStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
  SPAM
}
