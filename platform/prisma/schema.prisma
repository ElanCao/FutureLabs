// SkillTree — Prisma schema
// Follows skilltree.schema.json field names

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// NextAuth required models
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Core SkillTree models
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  profile  Profile?
}

model Profile {
  id          String      @id @default(cuid())
  username    String      @unique
  displayName String?
  bio         String?
  avatarUrl   String?
  avatarEmoji String?
  entityType  EntityType  @default(human)
  privacy     Privacy     @default(private)
  totalXp     Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // nullable — AI agent profiles have no user account
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  skillRecords UserSkillRecord[]
}

model Branch {
  id          String   @id // e.g. "engineering"
  name        String
  description String?
  icon        String?
  color       String?  // hex color e.g. "#6366f1"
  createdAt   DateTime @default(now())

  skills Skill[]
}

model Skill {
  id            String   @id // URL-safe slug e.g. "typescript"
  name          String
  branchId      String
  parentSkillId String?
  description   String?
  icon          String?
  maxLevel      Int      @default(10)
  prerequisites String[] // array of skill IDs
  tags          String[]
  agentCompat   Boolean  @default(true)
  community     Boolean  @default(false)
  levelsJson    Json     // array of SkillLevel objects (level, title, behavioral_description, xp_threshold)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch       Branch            @relation(fields: [branchId], references: [id])
  parentSkill  Skill?            @relation("SkillHierarchy", fields: [parentSkillId], references: [id])
  childSkills  Skill[]           @relation("SkillHierarchy")
  skillRecords UserSkillRecord[]
}

model UserSkillRecord {
  id           String    @id @default(cuid())
  profileId    String
  skillId      String
  currentLevel Int       @default(0)
  xp           Int       @default(0)
  unlockedAt   DateTime?
  lastLeveledAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile         Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill           Skill           @relation(fields: [skillId], references: [id])
  evidenceRecords EvidenceRecord[]

  @@unique([profileId, skillId])
}

model EvidenceRecord {
  id               String       @id @default(cuid())
  userSkillRecordId String
  type             EvidenceType
  title            String?
  url              String?
  description      String?
  verified         Boolean      @default(false)
  createdAt        DateTime     @default(now())

  userSkillRecord UserSkillRecord @relation(fields: [userSkillRecordId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum EntityType {
  human
  ai_agent
}

enum Privacy {
  public
  friends
  private
}

enum EvidenceType {
  certificate
  project
  self_assessment
  peer_review
  publication
  contribution
}
