generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model ApiKey {
  id         String    @id
  profileId  String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  Profile    Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Branch {
  id          String   @id
  name        String
  description String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now())
  Skill       Skill[]
}

model EmailOtp {
  id         String   @id
  email      String
  codeHash   String
  attempts   Int      @default(0)
  lastSentAt DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([email])
}

model EvidenceRecord {
  id                String          @id
  userSkillRecordId String
  type              EvidenceType
  title             String?
  url               String?
  description       String?
  verified          Boolean         @default(false)
  createdAt         DateTime        @default(now())
  UserSkillRecord   UserSkillRecord @relation(fields: [userSkillRecordId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id
  profileId   String
  type        String
  referenceId String?
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  Profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Profile {
  id                                                    String             @id
  username                                              String             @unique
  displayName                                           String?
  bio                                                   String?
  avatarUrl                                             String?
  avatarEmoji                                           String?
  entityType                                            EntityType         @default(human)
  privacy                                               Privacy            @default(private)
  totalXp                                               Int                @default(0)
  createdAt                                             DateTime           @default(now())
  updatedAt                                             DateTime
  userId                                                String?            @unique
  ApiKey                                                ApiKey[]
  Notification                                          Notification[]
  User                                                  User?              @relation(fields: [userId], references: [id])
  SkillEndorsement_SkillEndorsement_endorseeIdToProfile SkillEndorsement[] @relation("SkillEndorsement_endorseeIdToProfile")
  SkillEndorsement_SkillEndorsement_endorserIdToProfile SkillEndorsement[] @relation("SkillEndorsement_endorserIdToProfile")
  UserSkillRecord                                       UserSkillRecord[]
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Skill {
  id               String             @id
  name             String
  branchId         String
  parentSkillId    String?
  description      String?
  icon             String?
  maxLevel         Int                @default(10)
  prerequisites    String[]
  tags             String[]
  agentCompat      Boolean            @default(true)
  community        Boolean            @default(false)
  levelsJson       Json
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  subDomain        String?
  workRelevant     Boolean            @default(false)
  lifeSkill        Boolean            @default(false)
  verifiable       Boolean            @default(false)
  trending         Boolean            @default(false)
  localizationTags String[]           @default([])
  Branch           Branch             @relation(fields: [branchId], references: [id])
  Skill            Skill?             @relation("SkillToSkill", fields: [parentSkillId], references: [id])
  other_Skill      Skill[]            @relation("SkillToSkill")
  SkillEndorsement SkillEndorsement[]
  UserSkillRecord  UserSkillRecord[]
}

model SkillEndorsement {
  id                                           String   @id
  endorserId                                   String
  endorseeId                                   String
  skillId                                      String
  note                                         String?
  createdAt                                    DateTime @default(now())
  Profile_SkillEndorsement_endorseeIdToProfile Profile  @relation("SkillEndorsement_endorseeIdToProfile", fields: [endorseeId], references: [id], onDelete: Cascade)
  Profile_SkillEndorsement_endorserIdToProfile Profile  @relation("SkillEndorsement_endorserIdToProfile", fields: [endorserId], references: [id], onDelete: Cascade)
  Skill                                        Skill    @relation(fields: [skillId], references: [id])

  @@unique([endorserId, endorseeId, skillId])
}

model User {
  id            String    @id
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  password      String?
  Account       Account[]
  Profile       Profile?
  Session       Session[]
}

model UserSkillRecord {
  id             String           @id
  profileId      String
  skillId        String
  currentLevel   Int              @default(0)
  xp             Int              @default(0)
  unlockedAt     DateTime?
  lastLeveledAt  DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  EvidenceRecord EvidenceRecord[]
  Profile        Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  Skill          Skill            @relation(fields: [skillId], references: [id])

  @@unique([profileId, skillId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum EntityType {
  human
  ai_agent
}

enum EvidenceType {
  certificate
  project
  self_assessment
  peer_review
  publication
  contribution
}

enum Privacy {
  public
  friends
  private
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  status    ContactStatus @default(UNREAD)
  source    String   @default("website")
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  repliedAt DateTime?
  repliedBy String?
  notes     String?  @db.Text

  @@index([status, createdAt])
  @@index([email])
  @@index([createdAt])
}

enum ContactStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
  SPAM
}
