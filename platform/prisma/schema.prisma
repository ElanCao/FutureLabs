generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EntityType {
  human
  ai_agent
}

enum Privacy {
  public
  friends
  private
}

enum EvidenceType {
  certificate
  project
  self_assessment
  peer_review
  publication
  contribution
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
}

model Profile {
  id                  String              @id @default(cuid())
  username            String              @unique
  displayName         String?
  bio                 String?
  avatarUrl           String?
  avatarEmoji         String?
  entityType          EntityType          @default(human)
  privacy             Privacy             @default(private)
  totalXp             Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  userId              String?             @unique
  user                User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  skills              UserSkillRecord[]
  givenEndorsements   SkillEndorsement[]  @relation("GivenEndorsements")
  receivedEndorsements SkillEndorsement[] @relation("ReceivedEndorsements")
  notifications       Notification[]
  apiKeys             ApiKey[]
}

model ApiKey {
  id          String    @id @default(cuid())
  profileId   String
  name        String
  keyHash     String    @unique
  keyPrefix   String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Branch {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now())
  skills      Skill[]
}

model Skill {
  id            String             @id @default(cuid())
  name          String
  branchId      String
  parentSkillId String?
  description   String?
  icon          String?
  maxLevel      Int                @default(10)
  prerequisites String[]
  tags          String[]
  agentCompat   Boolean            @default(true)
  community     Boolean            @default(false)
  levelsJson    Json
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  branch        Branch             @relation(fields: [branchId], references: [id])
  parentSkill   Skill?             @relation("SkillParent", fields: [parentSkillId], references: [id])
  childSkills   Skill[]            @relation("SkillParent")
  userRecords   UserSkillRecord[]
  endorsements  SkillEndorsement[]
}

model UserSkillRecord {
  id           String          @id @default(cuid())
  profileId    String
  skillId      String
  currentLevel Int             @default(0)
  xp           Int             @default(0)
  unlockedAt   DateTime?
  lastLeveledAt DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  profile      Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill        Skill           @relation(fields: [skillId], references: [id])
  evidence     EvidenceRecord[]

  @@unique([profileId, skillId])
}

model EvidenceRecord {
  id                String          @id @default(cuid())
  userSkillRecordId String
  type              EvidenceType
  title             String?
  url               String?
  description       String?
  verified          Boolean         @default(false)
  createdAt         DateTime        @default(now())
  userSkillRecord   UserSkillRecord @relation(fields: [userSkillRecordId], references: [id], onDelete: Cascade)
}

model SkillEndorsement {
  id          String   @id @default(cuid())
  endorserId  String
  endorseeId  String
  skillId     String
  note        String?
  createdAt   DateTime @default(now())
  endorser    Profile  @relation("GivenEndorsements", fields: [endorserId], references: [id], onDelete: Cascade)
  endorsee    Profile  @relation("ReceivedEndorsements", fields: [endorseeId], references: [id], onDelete: Cascade)
  skill       Skill    @relation(fields: [skillId], references: [id])

  @@unique([endorserId, endorseeId, skillId])
}

model Notification {
  id          String   @id @default(cuid())
  profileId   String
  type        String
  referenceId String?
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}
