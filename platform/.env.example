# ============================================================
# Environment Configuration
# Copy this file to .env.local for local development.
# Never commit .env.local or any file with real secrets.
# ============================================================

# ------------------------------------
# Site
# ------------------------------------
# Public URL for canonical links, OG tags, sitemaps
NEXT_PUBLIC_SITE_URL=https://futurelabs.vip

# ------------------------------------
# Database (Supabase / Railway / Neon)
# ------------------------------------
# Pooled connection — used by Prisma at runtime (via pgBouncer)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB?pgbouncer=true&connection_limit=1

# Direct (non-pooled) connection — used by Prisma for migrations
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DB

# ------------------------------------
# NextAuth
# ------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here

# Set to your deployment URL (no trailing slash)
NEXTAUTH_URL=https://futurelabs.vip

# ------------------------------------
# Google OAuth
# ------------------------------------
# https://console.developers.google.com/apis/credentials
# Authorized redirect URI: https://futurelabs.vip/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------
# GitHub OAuth
# ------------------------------------
# https://github.com/settings/developers → New OAuth App
# Callback URL: https://futurelabs.vip/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ------------------------------------
# Analytics (optional)
# ------------------------------------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ------------------------------------
# Contact form (optional)
# ------------------------------------
# If using a form backend (e.g. Resend, Sendgrid)
# CONTACT_FORM_API_KEY=
# CONTACT_FORM_TO_EMAIL=hello@example.com

# ------------------------------------
# Uptime / Monitoring (optional)
# ------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=
